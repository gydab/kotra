---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { requireRole } from '@lib/admin-auth';
import { supabase } from '@lib/supabase';

const user = await requireRole(Astro, ['admin', 'tournament_director']);

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const { error: insertError } = await supabase.from('tournaments').insert({
    name_is: form.get('name_is') ?? '',
    name_en: form.get('name_en') ?? '',
    date: form.get('date') || null,
    location: form.get('location') || null,
    type: form.get('type') || 'domestic',
    description_is: form.get('description_is') ?? '',
    description_en: form.get('description_en') ?? '',
    status: form.get('status') || 'upcoming',
    wbif_link: form.get('wbif_link') || null,
  });

  if (insertError) {
    error = insertError.message;
  } else {
    return Astro.redirect('/admin/mot');
  }
}
---

<AdminLayout title="Nýtt mót" user={user} activeSection="mot">
  <div class="mb-6">
    <a href="/admin/mot" class="text-sm text-gray-500 hover:text-gray-700">← Til baka</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">Nýtt mót</h1>
  </div>

  {error && <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg p-4 mb-4">{error}</div>}

  <div class="admin-card p-6">
    <form method="POST" class="space-y-6">
      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="admin-label">Heiti (IS)</label>
          <input type="text" name="name_is" class="admin-input" required />
        </div>
        <div>
          <label class="admin-label">Heiti (EN)</label>
          <input type="text" name="name_en" class="admin-input" />
        </div>
      </div>

      <div class="grid grid-cols-3 gap-6">
        <div>
          <label class="admin-label">Dagsetning</label>
          <input type="date" name="date" class="admin-input" />
        </div>
        <div>
          <label class="admin-label">Staður</label>
          <input type="text" name="location" class="admin-input" />
        </div>
        <div>
          <label class="admin-label">Tegund</label>
          <select name="type" class="admin-input">
            <option value="domestic">Innlent</option>
            <option value="wbif">WBIF</option>
            <option value="friendly">Vináttu</option>
            <option value="other">Annað</option>
          </select>
        </div>
      </div>

      <div>
        <label class="admin-label">Staða</label>
        <select name="status" class="admin-input" style="max-width: 200px;">
          <option value="upcoming">Komandi</option>
          <option value="active">Í gangi</option>
          <option value="completed">Lokið</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="admin-label">Lýsing (IS)</label>
          <textarea name="description_is" class="admin-textarea"></textarea>
        </div>
        <div>
          <label class="admin-label">Lýsing (EN)</label>
          <textarea name="description_en" class="admin-textarea"></textarea>
        </div>
      </div>

      <div>
        <label class="admin-label">WBIF tengill</label>
        <input type="url" name="wbif_link" class="admin-input" placeholder="https://wbif.net/..." />
      </div>

      <div class="flex gap-3">
        <button type="submit" class="admin-btn-primary">Vista mót</button>
        <a href="/admin/mot" class="admin-btn-secondary">Hætta við</a>
      </div>
    </form>
  </div>
</AdminLayout>
