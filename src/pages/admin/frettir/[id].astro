---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { requireAdmin } from '@lib/admin-auth';
import { supabase } from '@lib/supabase';

const user = await requireAdmin(Astro);
const id = Astro.params.id;

let error = '';
let success = '';

function slugify(input: string) {
  return input
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'delete') {
    const { error: deleteError } = await supabase.from('news').delete().eq('id', id);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/admin/frettir');
    }
  } else {
    const title_is = formData.get('title_is')?.toString().trim() ?? '';
    const title_en = formData.get('title_en')?.toString().trim() ?? '';
    const body_is = formData.get('body_is')?.toString().trim() ?? '';
    const body_en = formData.get('body_en')?.toString().trim() ?? '';
    const slugInput = formData.get('slug')?.toString().trim() ?? '';
    const published = formData.get('published') === 'on';
    const published_date = formData.get('published_date')?.toString().trim() ?? '';

    const slug = slugInput || slugify(title_is || title_en || 'frett');

    const { error: updateError } = await supabase
      .from('news')
      .update({
        title_is,
        title_en,
        body_is,
        body_en,
        slug,
        published,
        published_date: published_date ? new Date(published_date).toISOString() : null,
        author: user.email,
      })
      .eq('id', id);

    if (updateError) {
      error = updateError.message;
    } else {
      success = 'Frétt vistuð.';
    }
  }
}

const { data: newsItem, error: fetchError } = await supabase
  .from('news')
  .select('*')
  .eq('id', id)
  .single();

if (fetchError || !newsItem) {
  return Astro.redirect('/admin/frettir');
}
---

<AdminLayout title="Breyta frétt" user={user} activeSection="frettir">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Breyta frétt</h1>
      <p class="text-gray-500 text-sm mt-1">Titlar og meginmál á íslensku og ensku.</p>
    </div>
    <form method="POST" onsubmit="return confirm('Eyða frétt?');">
      <input type="hidden" name="action" value="delete" />
      <button type="submit" class="admin-btn-danger text-sm">Eyða</button>
    </form>
  </div>

  <form method="POST" class="admin-card p-6 space-y-5">
    {error && (
      <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm border border-red-200">
        {error}
      </div>
    )}
    {success && (
      <div class="bg-green-50 text-green-700 px-4 py-3 rounded-lg text-sm border border-green-200">
        {success}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="admin-label" for="title_is">Titill (IS)</label>
        <input class="admin-input" id="title_is" name="title_is" value={newsItem.title_is} required />
      </div>
      <div>
        <label class="admin-label" for="title_en">Titill (EN)</label>
        <input class="admin-input" id="title_en" name="title_en" value={newsItem.title_en} />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="admin-label" for="body_is">Meginmál (IS)</label>
        <textarea class="admin-textarea" id="body_is" name="body_is">{newsItem.body_is}</textarea>
      </div>
      <div>
        <label class="admin-label" for="body_en">Meginmál (EN)</label>
        <textarea class="admin-textarea" id="body_en" name="body_en">{newsItem.body_en}</textarea>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div>
        <label class="admin-label" for="slug">Slug</label>
        <input class="admin-input" id="slug" name="slug" value={newsItem.slug} />
      </div>
      <div>
        <label class="admin-label" for="published_date">Birtingardagur</label>
        <input
          class="admin-input"
          id="published_date"
          name="published_date"
          type="date"
          value={newsItem.published_date ? new Date(newsItem.published_date).toISOString().split('T')[0] : ''}
        />
      </div>
      <div class="flex items-end gap-3">
        <label class="admin-label flex items-center gap-2 mb-0">
          <input type="checkbox" name="published" class="h-4 w-4" checked={newsItem.published} />
          Birta
        </label>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <input type="hidden" name="action" value="update" />
      <button type="submit" class="admin-btn-primary">Vista breytingar</button>
      <a href="/admin/frettir" class="admin-btn-secondary">Til baka</a>
    </div>
  </form>
</AdminLayout>
