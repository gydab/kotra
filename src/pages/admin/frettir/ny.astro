---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { requireAdmin } from '@lib/admin-auth';
import { supabase } from '@lib/supabase';

const user = await requireAdmin(Astro);

let error = '';

function slugify(input: string) {
  return input
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title_is = formData.get('title_is')?.toString().trim() ?? '';
  const title_en = formData.get('title_en')?.toString().trim() ?? '';
  const body_is = formData.get('body_is')?.toString().trim() ?? '';
  const body_en = formData.get('body_en')?.toString().trim() ?? '';
  const slugInput = formData.get('slug')?.toString().trim() ?? '';
  const published = formData.get('published') === 'on';
  const published_date = formData.get('published_date')?.toString().trim() ?? '';

  const slug = slugInput || slugify(title_is || title_en || 'frett');

  const { data, error: insertError } = await supabase
    .from('news')
    .insert({
      title_is,
      title_en,
      body_is,
      body_en,
      slug,
      published,
      published_date: published_date ? new Date(published_date).toISOString() : null,
      author: user.email,
    })
    .select('id')
    .single();

  if (insertError || !data) {
    error = insertError?.message || 'Ekki tókst að vista.';
  } else {
    return Astro.redirect(`/admin/frettir/${data.id}`);
  }
}
---

<AdminLayout title="Ný frétt" user={user} activeSection="frettir">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Ný frétt</h1>
      <p class="text-gray-500 text-sm mt-1">Skrifaðu frétt á íslensku og ensku.</p>
    </div>
  </div>

  <form method="POST" class="admin-card p-6 space-y-5">
    {error && (
      <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm border border-red-200">
        {error}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="admin-label" for="title_is">Titill (IS)</label>
        <input class="admin-input" id="title_is" name="title_is" required />
      </div>
      <div>
        <label class="admin-label" for="title_en">Titill (EN)</label>
        <input class="admin-input" id="title_en" name="title_en" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="admin-label" for="body_is">Meginmál (IS)</label>
        <textarea class="admin-textarea" id="body_is" name="body_is"></textarea>
      </div>
      <div>
        <label class="admin-label" for="body_en">Meginmál (EN)</label>
        <textarea class="admin-textarea" id="body_en" name="body_en"></textarea>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div>
        <label class="admin-label" for="slug">Slug (valfrjálst)</label>
        <input class="admin-input" id="slug" name="slug" placeholder="frett-slug" />
      </div>
      <div>
        <label class="admin-label" for="published_date">Birtingardagur</label>
        <input class="admin-input" id="published_date" name="published_date" type="date" />
      </div>
      <div class="flex items-end gap-3">
        <label class="admin-label flex items-center gap-2 mb-0">
          <input type="checkbox" name="published" class="h-4 w-4" />
          Birta strax
        </label>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="admin-btn-primary">Vista og halda áfram</button>
      <a href="/admin/frettir" class="admin-btn-secondary">Hætta við</a>
    </div>
  </form>
</AdminLayout>
