---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="is">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Innskráning — Kotra Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex items-center justify-center gradient-hero">
  <div class="w-full max-w-sm mx-4">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 gradient-cta rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🎲</div>
      <h1 class="text-white text-2xl font-semibold" style="font-family: 'Plus Jakarta Sans', sans-serif;">
        Kotra Admin
      </h1>
      <p class="text-white/50 text-sm mt-1">Innskráning stjórnborðs</p>
    </div>

    <!-- Login Form -->
    <form id="login-form" class="bg-white rounded-2xl shadow-2xl p-8 space-y-5">
      <div id="error-box" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm border border-red-200"></div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
          Netfang
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="admin@kotra.is"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-500"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
          Lykilorð
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="••••••••"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-500"
        />
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full gradient-cta text-white py-2.5 rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity cursor-pointer"
      >
        Skrá inn
      </button>

      <div class="text-center">
        <a href="/is" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">
          ← Til baka á forsíðu
        </a>
      </div>
    </form>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    const form = document.getElementById('login-form');
    const errorBox = document.getElementById('error-box');
    const submitBtn = document.getElementById('submit-btn');

    function showError(msg: string) {
      errorBox!.textContent = msg;
      errorBox!.classList.remove('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox!.classList.add('hidden');
      submitBtn!.textContent = 'Augnablik...';
      submitBtn!.setAttribute('disabled', 'true');

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      try {
        const { data, error: authError } = await supabase.auth.signInWithPassword({
          email,
          password,
        });

        if (authError) {
          showError('Rangt netfang eða lykilorð.');
          submitBtn!.textContent = 'Skrá inn';
          submitBtn!.removeAttribute('disabled');
          return;
        }

        if (data.session) {
          // Check if user is admin
          const { data: adminProfile, error: profileError } = await supabase
            .from('admin_profiles')
            .select('id')
            .eq('id', data.user.id)
            .single();

          if (profileError || !adminProfile) {
            showError('Þú hefur ekki admin aðgang.');
            await supabase.auth.signOut();
            submitBtn!.textContent = 'Skrá inn';
            submitBtn!.removeAttribute('disabled');
            return;
          }

          // Set cookies via API
          const res = await fetch('/admin/api/set-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              access_token: data.session.access_token,
              refresh_token: data.session.refresh_token,
            }),
          });

          if (res.ok) {
            window.location.href = '/admin';
          } else {
            showError('Villa við innskráningu.');
            submitBtn!.textContent = 'Skrá inn';
            submitBtn!.removeAttribute('disabled');
          }
        }
      } catch (err) {
        showError('Villa við innskráningu.');
        submitBtn!.textContent = 'Skrá inn';
        submitBtn!.removeAttribute('disabled');
      }
    });
  </script>
</body>
</html>

<style is:global>
  @import '../../styles/global.css';
</style>
