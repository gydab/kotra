---
export const prerender = false;

import { getAdminUser } from '@lib/admin-auth';
import { supabase } from '@lib/supabase';

// If already logged in, redirect to admin dashboard
const user = await getAdminUser(Astro);
if (user) {
  return Astro.redirect('/admin');
}

let error = '';

// Handle login form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  const { data, error: authError } = await supabase.auth.signInWithPassword({
    email,
    password,
  });

  if (authError) {
    error = 'Rangt netfang eða lykilorð.';
  } else if (data.session) {
    // Check if user is admin
    const { data: adminProfile } = await supabase
      .from('admin_profiles')
      .select('id')
      .eq('id', data.user.id)
      .single();

    if (!adminProfile) {
      error = 'Þú hefur ekki admin aðgang.';
      await supabase.auth.signOut();
    } else {
      // Set auth cookies
      Astro.cookies.set('sb-access-token', data.session.access_token, {
        path: '/',
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        maxAge: 60 * 60, // 1 hour
      });
      Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
        path: '/',
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        maxAge: 60 * 60 * 24 * 7, // 7 days
      });

      return Astro.redirect('/admin');
    }
  }
}
---

<!DOCTYPE html>
<html lang="is">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Innskráning — Kotra Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex items-center justify-center gradient-hero">
  <div class="w-full max-w-sm mx-4">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 gradient-cta rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🎲</div>
      <h1 class="text-white text-2xl font-semibold" style="font-family: 'Plus Jakarta Sans', sans-serif;">
        Kotra Admin
      </h1>
      <p class="text-white/50 text-sm mt-1">Innskráning stjórnborðs</p>
    </div>

    <!-- Login Form -->
    <form method="POST" class="bg-white rounded-2xl shadow-2xl p-8 space-y-5">
      {error && (
        <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm border border-red-200">
          {error}
        </div>
      )}

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
          Netfang
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="admin@kotra.is"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-500"
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
          Lykilorð
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="••••••••"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-500"
        />
      </div>

      <button
        type="submit"
        class="w-full gradient-cta text-white py-2.5 rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity cursor-pointer"
      >
        Skrá inn
      </button>

      <div class="text-center">
        <a href="/is" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">
          ← Til baka á forsíðu
        </a>
      </div>
    </form>
  </div>
</body>
</html>

<style is:global>
  @import '../../styles/global.css';
</style>
