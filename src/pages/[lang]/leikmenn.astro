---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import type { Locale } from '@i18n/index';
import { t } from '@i18n/index';
import { supabase } from '@lib/supabase';
import { getWBIFProfileUrl, formatRating, formatExperience, getPRCategory, getPRCategoryIs, getRatingBadge } from '@lib/wbif';

const lang = (Astro.params.lang ?? 'is') as Locale;
const i = t(lang);
const isIs = lang === 'is';

// Fetch Icelandic players from the players table
const { data: players } = await supabase
  .from('players')
  .select('*')
  .eq('country', 'IS')
  .eq('active', true)
  .order('wbif_rating', { ascending: false, nullsFirst: false });

const playerList = players ?? [];
const totalPlayers = playerList.length;
const avgRating = totalPlayers > 0
  ? Math.round(playerList.reduce((sum, p) => sum + (p.wbif_rating ?? p.rating ?? 0), 0) / totalPlayers)
  : 0;
const highestRated = playerList[0];

const titles: Record<Locale, string> = {
  is: 'Íslenskir spilarar — Kotrusambandið',
  en: 'Icelandic Players — Kotrusambandið',
};
---

<BaseLayout locale={lang} title={titles[lang]}>
  <!-- Hero -->
  <section class="gradient-hero pt-24 pb-16 text-center relative overflow-hidden">
    <div class="absolute -top-1/2 -right-1/5 w-[600px] h-[600px] bg-[radial-gradient(circle,rgba(174,68,90,0.15)_0%,transparent_70%)] rounded-full"></div>
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 px-4 py-1.5 rounded-full text-white/70 text-xs font-medium mb-6 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 bg-gold rounded-full animate-pulse-dot"></span>
        WBIF
      </div>
      <h1 class="text-4xl md:text-5xl text-white mb-4 tracking-tight" style="font-family: var(--font-heading);">
        {isIs ? 'Íslenskir kotrumeistarar' : 'Icelandic Backgammon Players'}
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto mb-8">
        {isIs
          ? 'Allir íslenskir spilarar skráðir hjá WBIF — World Backgammon Internet Federation.'
          : 'All Icelandic players registered with WBIF — World Backgammon Internet Federation.'}
      </p>

      <!-- Summary stats -->
      <div class="flex justify-center gap-8 flex-wrap">
        <div class="text-center">
          <div class="text-3xl font-bold text-gold" style="font-family: var(--font-mono);">{totalPlayers}</div>
          <div class="text-xs text-white/40 uppercase tracking-wider mt-1">{isIs ? 'Spilarar' : 'Players'}</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white" style="font-family: var(--font-mono);">{avgRating}</div>
          <div class="text-xs text-white/40 uppercase tracking-wider mt-1">{isIs ? 'Meðalrating' : 'Avg Rating'}</div>
        </div>
        {highestRated && (
          <div class="text-center">
            <div class="text-3xl font-bold text-white" style="font-family: var(--font-mono);">{formatRating(highestRated.wbif_rating ?? 0)}</div>
            <div class="text-xs text-white/40 uppercase tracking-wider mt-1">{isIs ? 'Hæsta rating' : 'Highest Rating'}</div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Wave -->
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="block w-full h-[60px] bg-[#451952]">
    <path fill="#F0E6F0" d="M0,20 C480,50 960,0 1440,20 L1440,60 L0,60 Z"/>
  </svg>

  <!-- Players list -->
  <section class="bg-lavender py-12 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Table/card view -->
      <div class="overflow-hidden rounded-2xl border border-deep-purple/10 shadow-[0_4px_30px_rgba(69,25,82,0.08)]">
        <!-- Desktop table -->
        <div class="hidden lg:block">
          <table class="w-full">
            <thead>
              <tr class="bg-deep-purple/5 border-b border-deep-purple/10">
                <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">#</th>
                <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">{isIs ? 'Nafn' : 'Name'}</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">Rating</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">EXP</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">PR</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">{isIs ? 'Leikir' : 'Matches'}</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">{isIs ? 'Sigur%' : 'Win%'}</th>
                <th class="text-center px-6 py-3 text-xs font-bold uppercase tracking-wider text-deep-purple/50">WBIF</th>
              </tr>
            </thead>
            <tbody>
              {playerList.map((player: any, index: number) => {
                const rating = player.wbif_rating ?? player.rating ?? 0;
                const badge = getRatingBadge(rating);
                return (
                  <tr class="bg-white border-b border-deep-purple/5 hover:bg-lavender/50 transition-colors">
                    <td class="px-6 py-4">
                      <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold ${
                        index === 0 ? 'bg-amber-100 text-amber-700' :
                        index === 1 ? 'bg-gray-100 text-gray-600' :
                        index === 2 ? 'bg-orange-100 text-orange-700' :
                        'bg-deep-purple/5 text-deep-purple/40'
                      }`}>{index + 1}</span>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full gradient-hero flex items-center justify-center text-white text-sm font-bold shadow-sm">
                          {player.name.charAt(0)}
                        </div>
                        <div>
                          <div class="font-semibold text-deep-purple text-sm">{player.name}</div>
                          {player.wbif_title && (
                            <span class="text-[10px] bg-deep-purple/8 text-deep-purple/60 px-2 py-0.5 rounded-full font-medium">{player.wbif_title}</span>
                          )}
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <span class="font-bold text-deep-purple" style="font-family: var(--font-mono);">{formatRating(rating)}</span>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <span class="text-sm text-muted-text" style="font-family: var(--font-mono);">{formatExperience(player.wbif_experience ?? 0)}</span>
                    </td>
                    <td class="px-6 py-4 text-right">
                      {player.wbif_pr_overall ? (
                        <span class="text-sm font-medium" style="font-family: var(--font-mono);">
                          {player.wbif_pr_overall.toFixed(1)}
                        </span>
                      ) : (
                        <span class="text-sm text-muted-text">—</span>
                      )}
                    </td>
                    <td class="px-6 py-4 text-right">
                      <span class="text-sm text-muted-text" style="font-family: var(--font-mono);">{player.wbif_matches_recorded ?? '—'}</span>
                    </td>
                    <td class="px-6 py-4 text-right">
                      {player.wbif_win_rate ? (
                        <span class="text-sm font-medium" style="font-family: var(--font-mono);">{player.wbif_win_rate}%</span>
                      ) : (
                        <span class="text-sm text-muted-text">—</span>
                      )}
                    </td>
                    <td class="px-6 py-4 text-center">
                      {player.wbif_id ? (
                        <a
                          href={getWBIFProfileUrl(player.wbif_id)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 text-xs font-semibold text-berry hover:text-gold transition-colors"
                        >
                          {isIs ? 'Prófíll' : 'Profile'} ↗
                        </a>
                      ) : (
                        <span class="text-xs text-muted-text">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <!-- Mobile cards -->
        <div class="lg:hidden divide-y divide-deep-purple/5">
          {playerList.map((player: any, index: number) => {
            const rating = player.wbif_rating ?? player.rating ?? 0;
            return (
              <div class="bg-white p-5 flex items-start gap-4">
                <div class="flex-shrink-0">
                  <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold ${
                    index === 0 ? 'bg-amber-100 text-amber-700' :
                    index === 1 ? 'bg-gray-100 text-gray-600' :
                    index === 2 ? 'bg-orange-100 text-orange-700' :
                    'bg-deep-purple/5 text-deep-purple/40'
                  }`}>{index + 1}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-deep-purple text-sm">{player.name}</div>
                  {player.wbif_title && (
                    <span class="text-[10px] bg-deep-purple/8 text-deep-purple/60 px-2 py-0.5 rounded-full font-medium inline-block mt-1">{player.wbif_title}</span>
                  )}
                  <div class="flex gap-4 mt-2 text-xs text-muted-text">
                    <span><strong class="text-deep-purple">{formatRating(rating)}</strong> rating</span>
                    <span>{formatExperience(player.wbif_experience ?? 0)} exp</span>
                    {player.wbif_pr_overall && <span>PR {player.wbif_pr_overall.toFixed(1)}</span>}
                  </div>
                </div>
                {player.wbif_id && (
                  <a
                    href={getWBIFProfileUrl(player.wbif_id)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-berry hover:text-gold transition-colors flex-shrink-0"
                  >
                    WBIF ↗
                  </a>
                )}
              </div>
            );
          })}
        </div>
      </div>

      <!-- WBIF info -->
      <div class="mt-8 text-center">
        <p class="text-sm text-muted-text">
          {isIs
            ? 'Gögn frá '
            : 'Data from '}
          <a href="https://matches.wbif.net/wbif/ratings" target="_blank" rel="noopener noreferrer" class="text-berry hover:text-gold font-semibold transition-colors">
            WBIF — World Backgammon Internet Federation
          </a>
        </p>
        <p class="text-xs text-muted-text/60 mt-1">
          {isIs
            ? 'Rating og tölfræði eru uppfærð reglulega. Nýir spilarar byrja á 1.500 rating.'
            : 'Ratings and statistics are updated regularly. New players start at 1,500 rating.'}
        </p>
      </div>
    </div>
  </section>

  <!-- Wave to dark footer -->
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="block w-full h-[60px] bg-lavender">
    <path fill="#451952" d="M0,20 C480,50 960,0 1440,20 L1440,60 L0,60 Z"/>
  </svg>
</BaseLayout>
